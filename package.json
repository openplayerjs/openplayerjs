{
  "name": "openplayerjs",
  "version": "3.0.2",
  "description": "HTML5 video and audio player — monorepo root",
  "private": true,
  "author": {
    "name": "Rafael Miranda",
    "email": "rafa8626@gmail.com"
  },
  "repository": {
    "url": "https://github.com/openplayerjs/openplayerjs.git",
    "type": "git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "husky",

    "build": "pnpm run clean && pnpm run build:types && turbo run build:bundles build:css --force",
    "build:types": "tsc -b",
    "build:bundles": "turbo run build:bundles",
    "build:bundles:affected": "turbo run build:bundles --affected",
    "build:css": "turbo run build:css",
    "clean": "node -e \"const fs=require('fs'),p=require('path'),rm=x=>fs.rmSync(x,{recursive:true,force:true});if(fs.existsSync('packages'))for(const d of fs.readdirSync('packages',{withFileTypes:true}))if(d.isDirectory())rm(p.join('packages',d.name,'dist'));\"",

    "lint": "pnpm run lint:packages && pnpm run lint:css",
    "lint:packages": "eslint --cache packages",
    "lint:css": "stylelint packages/player/src/style.css",

    "test": "jest --coverage --passWithNoTests",
    "test:affected": "turbo run test --affected",
    "test:watch": "jest --watch --passWithNoTests",

    "watch": "turbo run watch",
    "watch:affected": "turbo run watch --affected",

    "release": "node scripts/orchestrate-release.mjs",
    "release:dry-run": "node scripts/orchestrate-release.mjs --dry-run",
    "release:major": "node scripts/orchestrate-release.mjs --increment major",
    "release:major:dry-run": "node scripts/orchestrate-release.mjs --increment major --dry-run",
    "release:minor": "node scripts/orchestrate-release.mjs --increment minor",
    "release:minor:dry-run": "node scripts/orchestrate-release.mjs --increment minor --dry-run",
    "release:patch": "node scripts/orchestrate-release.mjs --increment patch",
    "release:patch:dry-run": "node scripts/orchestrate-release.mjs --increment patch --dry-run",
    "release:pack": "pnpm -r --filter @openplayerjs/core --filter @openplayerjs/player --filter @openplayerjs/hls --filter @openplayerjs/ads --filter @openplayerjs/youtube pack --pack-destination ./packed"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "@release-it-plugins/workspaces": "^5.0.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@rollup/plugin-commonjs": "^29.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cssnano": "^7.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "hls.js": "^1.6.15",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "rollup": "^4.59.0",
    "stylelint": "^17.4.0",
    "stylelint-order": "^8.0.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "turbo": "^2.8.15",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "pnpm": "10.32.1",
    "node": ">=24.13.1"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "@tootallnate/once": ">=3.0.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-import>eslint": "^10"
      }
    }
  }
}
