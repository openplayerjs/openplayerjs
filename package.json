{
  "name": "openplayerjs",
  "version": "3.0.0-beta.2",
  "description": "HTML5 video and audio player — monorepo root",
  "private": true,
  "author": {
    "name": "Rafael Miranda",
    "email": "rafa8626@gmail.com"
  },
  "repository": {
    "url": "https://github.com/openplayerjs/openplayerjs.git",
    "type": "git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:bundles && npm run build:css",
    "build:types": "tsc -b",
    "build:css": "mkdir -p packages/player/dist && npm run lint:css && postcss packages/player/src/style.css -o packages/player/dist/openplayer.css",
    "build:bundles": "rollup -c rollup.config.mjs",
    "clean": "node -e \"const fs=require('fs'); const p=require('path'); const rm=(x)=>fs.rmSync(x,{recursive:true,force:true}); rm('dist'); if(fs.existsSync('packages')) for(const d of fs.readdirSync('packages',{withFileTypes:true})) if(d.isDirectory()) rm(p.join('packages',d.name,'dist'));\"",
    "lint": "npm run lint:packages && npm run lint:css",
    "lint:packages": "eslint --cache packages",
    "lint:css": "stylelint packages/player/src/style.css",
    "release": "dotenv -o -- release-it --config .release-it.cjs",
    "release:alpha": "dotenv -o -- release-it --config .release-it.cjs --preRelease=alpha",
    "release:beta": "dotenv -o -- release-it --config .release-it.cjs --preRelease=beta",
    "release:pack": "pnpm --filter @openplayerjs/core --filter @openplayerjs/player --filter @openplayerjs/hls --filter @openplayerjs/ads -r pack --pack-destination ./packed",
    "release:publish": "dotenv -o -- release-it --config .release-it.cjs --ci",
    "release:publish:dry-run": "dotenv -o -- release-it --config .release-it.cjs --ci --dry-run",
    "test": "jest --coverage --passWithNoTests",
    "watch": "npm run build:bundles -- --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it-plugins/workspaces": "^5.0.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^7.0.3",
    "cssnano": "^7.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "hls.js": "^1.6.15",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^30.2.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "pnpm": "10.30.1",
    "node": ">=24.13.1"
  },
  "packageManager": "pnpm@10.30.1"
}
