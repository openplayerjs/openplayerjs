{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "rootDir": "./src",
    "declarationDir": "./dist/types",
    "baseUrl": ".",
    "paths": {
      "@openplayer/core": [
        "../core/dist/types/index.d.ts"
      ],
      "@openplayer/core/*": [
        "../core/dist/types/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
