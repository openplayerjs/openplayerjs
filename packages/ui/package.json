{
  "name": "@openplayer/ui",
  "version": "3.0.0",
  "description": "UI layer, built-in controls, and accessibility for OpenPlayerJS",
  "author": {
    "name": "Rafael Miranda",
    "email": "rafa8626@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./style.css": "./dist/openplayer.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openplayerjs/openplayerjs.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "media",
    "video",
    "audio",
    "player",
    "openplayer",
    "ui",
    "controls"
  ],
  "peerDependencies": {
    "@openplayer/core": ">=3.0.0"
  },
  "scripts": {
    "prepack": "mkdir -p dist && postcss src/style.css -o dist/openplayer.css"
  }
}
