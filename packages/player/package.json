{
  "name": "@openplayerjs/player",
  "version": "3.0.2",
  "description": "UI layer, built-in controls, and accessibility for OpenPlayerJS",
  "author": {
    "name": "Rafael Miranda",
    "email": "rafa8626@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./openplayer.css": "./dist/openplayer.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openplayerjs/openplayerjs.git",
    "directory": "packages/player"
  },
  "keywords": [
    "media",
    "video",
    "audio",
    "player",
    "openplayer",
    "ui",
    "controls"
  ],
  "devDependencies": {
    "@openplayerjs/core": "workspace:^"
  },
  "peerDependencies": {
    "@openplayerjs/core": "workspace:^"
  },
  "scripts": {
    "prepack": "mkdir -p dist && postcss src/style.css -o dist/openplayer.css",
    "test": "jest --passWithNoTests --config ../../jest.config.cjs"
  },
  "publishConfig": {
    "access": "public"
  }
}
