{
  "name": "@openplayerjs/ads",
  "version": "3.4.0",
  "description": "VAST/VMAP/Non-linear/companions ad-serving plugin for OpenPlayerJS",
  "author": {
    "name": "Rafael Miranda",
    "email": "rafa8626@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openplayerjs/openplayerjs.git",
    "directory": "packages/ads"
  },
  "bugs": {
    "url": "https://github.com/openplayerjs/openplayerjs/issues"
  },
  "keywords": [
    "vast",
    "vmap",
    "ads",
    "ad",
    "advertising",
    "player",
    "openplayer"
  ],
  "scripts": {
    "build:bundles": "rollup -c rollup.config.cjs",
    "test": "jest --passWithNoTests  --config ../../jest.config.cjs",
    "release": "dotenv -o -- release-it --config .release-it.cjs",
    "watch": "rollup -c rollup.config.cjs --watch"
  },
  "dependencies": {
    "@dailymotion/vast-client": "^6.4.3",
    "@dailymotion/vmap": "^3.3.3"
  },
  "peerDependencies": {
    "@openplayerjs/core": "workspace:^"
  },
  "devDependencies": {
    "@types/dailymotion__vast-client": "^6.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
