{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "noEmit": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/types/**/*.ts",
    "packages/*/__tests__/**/*.ts",
    "__tests__/setup/**/*.ts",
    "e2e/**/*.ts",
    "playwright.config.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/*/dist"
  ]
}
