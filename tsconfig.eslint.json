{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/__tests__/**/*.ts",
    "packages/*/__tests__/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**"
  ]
}