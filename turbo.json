{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "packages/*/dist/**",
        "packages/*/umd/**"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "packages/*/coverage/**",
        "coverage/**"
      ]
    },
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "release": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    }
  }
}
